;; bmp.edn — Windows BMP (BITMAPFILEHEADER + BITMAPINFOHEADER) as EDN data.
;; Little-endian. R0 reads the headers (dims/bpp/compression); pixel data at
;; :data-offset is left as a blob pointer (not inlined). See ADR-2606272100.
{:meta  {:id :bmp :endian :little :root :bmp-file}

 :enums {:compression {0 :rgb 1 :rle8 2 :rle4 3 :bitfields 4 :jpeg 5 :png}}

 :types
 {:bmp-file
  [{:id :magic       :type :magic :value "BM"}
   {:id :file-size   :type :u32}
   {:id :_reserved   :type :skip  :size 4}
   {:id :data-offset :type :u32}
   {:id :dib-size    :type :u32}
   {:id :width       :type :i32}
   {:id :height      :type :i32}                         ; <0 = top-down
   {:id :planes      :type :u16}
   {:id :bpp         :type :u16}
   {:id :compression :type :u32 :enum :compression}
   {:id :image-size  :type :u32}
   {:id :xppm        :type :i32}
   {:id :yppm        :type :i32}
   {:id :colors      :type :u32}
   {:id :important   :type :u32}]}}

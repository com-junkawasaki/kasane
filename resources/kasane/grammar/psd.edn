;; psd.edn — Photoshop .psd binary grammar as EDN data (interpreted by
;; kasane.decode). This is *data*, not code: extending coverage = editing
;; this map. R0 covers the file header, color-mode/image-resource blobs and
;; the layer records. Channel image data is skipped via the outer
;; layer-and-mask :size-prefix (we seek past it). See ADR-2606272100.
{:meta  {:id :psd :endian :big :root :psd-file}

 :enums {:color-mode  {0 :bitmap 1 :gray 2 :indexed 3 :rgb 4 :cmyk 7 :multichannel 8 :duotone 9 :lab}
         :compression {0 :raw 1 :rle 2 :zip 3 :zip-prediction}}

 :types
 {:psd-file
  [{:id :sig    :type :magic :value "8BPS"}
   {:id :ver    :type :u16}
   {:id :_res   :type :skip  :size 6}
   {:id :chans  :type :u16}
   {:id :height :type :u32}
   {:id :width  :type :u32}
   {:id :depth  :type :u16}
   {:id :mode   :type :u16   :enum :color-mode}
   {:id :cmdata :type :blob  :size-prefix :u32}            ; color mode data
   {:id :res    :type :blob  :size-prefix :u32}            ; image resources
   {:id :limask :type :struct :of :layer-mask-info :size-prefix :u32}
   {:id :image  :type :struct :of :image-data}]

  :layer-mask-info
  [{:id :layerinfo-len :type :u32}
   {:id :count-raw     :type :i16}                         ; <0 = first alpha is transparency
   {:id :layers        :type :seq :count [:expr :abs [:field :count-raw]] :of :layer-record}]

  :layer-record
  [{:id :top    :type :i32}
   {:id :left   :type :i32}
   {:id :bottom :type :i32}
   {:id :right  :type :i32}
   {:id :nchan  :type :u16}
   {:id :chans  :type :seq :count [:field :nchan] :of :channel-info}
   {:id :blendsig :type :magic :value "8BIM"}
   {:id :blend  :type :str  :size 4}                       ; e.g. "norm" "mul " "scrn"
   {:id :opacity  :type :u8}
   {:id :clipping :type :u8}
   {:id :flags    :type :u8}
   {:id :filler   :type :u8}
   {:id :extra    :type :blob :size-prefix :u32}]          ; mask + ranges + name + addl (R0: opaque)

  :channel-info
  [{:id :id  :type :i16}
   {:id :len :type :u32}]

  :image-data
  [{:id :compression :type :u16 :enum :compression}]}}
